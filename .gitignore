############################################
# Terraform Core
############################################

# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Ignore plan output files
*.tfplan
*.plan

# CLI configuration files
.terraformrc
terraform.rc

############################################
# Sensitive Variable Files
############################################

# Variable definitions that may contain secrets
*.tfvars
*.tfvars.json

# Exception: allow example files
!*.example.tfvars
!*.example.tfvars.json

############################################
# Override Files
############################################

# Local override files (not meant for version control)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

############################################
# Terraform Lock File (Optional Strategy)
############################################

# Usually you SHOULD commit this for reproducibility
# Uncomment the next line ONLY if you intentionally want to ignore it
# .terraform.lock.hcl

############################################
# Provider & Plugin Caches
############################################

# Terraform plugin cache (if used locally)
plugin-cache/
.terraform.d/plugin-cache/

############################################
# Environment-specific files
############################################

# Local backend configs or secrets
backend.tfvars
backend.hcl

############################################
# OS / Editor Noise
############################################

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Linux
*~

############################################
# IDEs and Editors
############################################

# VS Code
.vscode/

# JetBrains (IntelliJ, PyCharm, etc.)
.idea/

############################################
# Logs & Misc
############################################

*.log
logs/